generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  USER
  ADMIN
}

enum TicketStatus {
  PENDING
  WON
  LOST
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DrawStatus {
  OPEN
  CLOSED
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum GridStatus {
  DRAFT
  OPEN
  CLOSED
  COMPLETED
}

enum SubTicketStatus {
  AVAILABLE
  RESERVED
  SOLD
  WON
}

model User {
  id               String     @id @default(cuid())
  name             String
  mobileNumber     String     @unique
  password         String
  role             Role       @default(USER)
  status           UserStatus @default(ACTIVE)
  isMobileVerified Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  purchases TicketPurchase[]
  Payment   Payment[]
  SubTicket SubTicket[]
  Ticket    Ticket[]
}

model MobileOtp {
  id           String   @id @default(cuid())
  mobileNumber String
  code         String
  expiresAt    DateTime
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Draw {
  id             String     @id @default(cuid())
  title          String
  drawAt         DateTime
  status         DrawStatus @default(OPEN)
  winningNumbers String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  payments Payment[]
  tickets  Ticket[]
}

model Payment {
  id         String   @id @default(cuid())
  userId     String
  purchaseId String   @unique
  amount     Decimal  @db.Decimal(10, 2)
  method     String?
  status     String
  createdAt  DateTime @default(now())

  user     User           @relation(fields: [userId], references: [id])
  purchase TicketPurchase @relation(fields: [purchaseId], references: [id])
  Draw     Draw?          @relation(fields: [drawId], references: [id])
  drawId   String?
  Ticket   Ticket[]
}

model Grid {
  id                String     @id @default(cuid())
  title             String
  openAt            DateTime
  closeAt           DateTime
  subTicketPrice    Decimal    @db.Decimal(10, 2)
  commissionRate    Decimal    @db.Decimal(5, 2)
  totalMainNumbers  Int        @default(100)
  subTicketsPerMain Int        @default(10)
  totalValue        Decimal    @db.Decimal(12, 2)
  commissionAmount  Decimal    @db.Decimal(12, 2)
  winningPool       Decimal    @db.Decimal(12, 2)
  winningNumber     Int?
  status            GridStatus @default(DRAFT)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  numbers   GridNumber[]
  purchases TicketPurchase[]
  Ticket    Ticket[]
}

model GridNumber {
  id        String   @id @default(cuid())
  gridId    String
  number    Int // 0 to 99
  isSoldOut Boolean  @default(false)
  createdAt DateTime @default(now())

  grid       Grid        @relation(fields: [gridId], references: [id], onDelete: Cascade)
  subTickets SubTicket[]

  @@unique([gridId, number])
}

model SubTicket {
  id           String          @id @default(cuid())
  gridNumberId String
  subIndex     Int
  status       SubTicketStatus @default(AVAILABLE)
  soldAt       DateTime?
  buyerId      String?
  purchaseId   String?

  gridNumber GridNumber      @relation(fields: [gridNumberId], references: [id], onDelete: Cascade)
  buyer      User?           @relation(fields: [buyerId], references: [id])
  purchase   TicketPurchase? @relation(fields: [purchaseId], references: [id])
  Ticket     Ticket?         @relation(fields: [ticketId], references: [id])
  ticketId   String?

  @@unique([gridNumberId, subIndex])
}

model Ticket {
  id          String   @id @default(cuid())
  userId      String
  gridId      String
  paymentId   String?
  totalAmount Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id])
  grid       Grid        @relation(fields: [gridId], references: [id])
  payment    Payment?    @relation(fields: [paymentId], references: [id])
  subTickets SubTicket[]
  Draw       Draw?       @relation(fields: [drawId], references: [id])
  drawId     String?
}

model TicketPurchase {
  id          String   @id @default(cuid())
  userId      String
  gridId      String
  totalAmount Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id])
  grid       Grid        @relation(fields: [gridId], references: [id])
  subTickets SubTicket[]
  payment    Payment?
}
