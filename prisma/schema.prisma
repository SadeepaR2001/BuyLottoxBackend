generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum TicketStatus {
  PENDING
  WON
  LOST
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DrawStatus {
  OPEN
  CLOSED
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets Ticket[]
  Payment Payment[]
}

model Draw {
  id             String     @id @default(cuid())
  title          String
  drawAt         DateTime
  status         DrawStatus @default(OPEN)
  winningNumbers String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  payments Payment[]
  tickets  Ticket[]
}

model Ticket {
  id        String       @id @default(cuid())
  userId    String
  drawId    String
  numbers   String
  status    TicketStatus @default(PENDING)
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])
  draw Draw @relation(fields: [drawId], references: [id])

  @@index([userId])
  @@index([drawId])
}

model Payment {
  id        String        @id @default(cuid())
  userId    String
  drawId    String
  amount    Float
  method    String
  reference String?
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id])
  draw Draw @relation(fields: [drawId], references: [id])

  @@index([userId])
  @@index([drawId])
}
